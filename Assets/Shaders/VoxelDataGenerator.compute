#pragma kernel CSPlanetVoxel
#pragma kernel CSMoonVoxel
#pragma kernel CSAsteroidVoxel

RWStructuredBuffer<float> _SdfOutput;

struct SdfComposeCommand
{
    int operation;
    int shape;
    float3 pointA;
    float radiusA;
    float3 pointB;
    float radiusB;
    float strength;
    float falloff;
    int flags;
    int otherBodyId;
};

StructuredBuffer<SdfComposeCommand> _ComposeCommands;
int _ComposeCommandCount;

